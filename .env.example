# ============================================================
# AI Roadmap Platform — Environment Variables
# ------------------------------------------------------------
# Copy this file to .env and fill in real values.
# NEVER commit .env. It's in .gitignore for a reason.
# ============================================================

# ----- Core -----
ENV=dev                            # dev | prod
PUBLIC_BASE_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080

# ----- Database -----
DATABASE_URL=sqlite+aiosqlite:////data/app.db

# ----- Auth / Sessions -----
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme_generate_a_real_32_byte_hex_string
JWT_EXPIRY_DAYS=30

# ----- Google OAuth2 -----
# Get from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# ----- SMTP for OTP email -----
# Free options: Brevo (300/day), Resend (3000/month), SendGrid (100/day)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=YOUR_SMTP_USER
SMTP_PASSWORD=YOUR_SMTP_PASSWORD
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=AI Roadmap

# ----- AI Providers -----
# Gemini — get from https://aistudio.google.com (free tier)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-1.5-flash

# Groq — get from https://console.groq.com (free tier)
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile

# Cerebras — get from https://cloud.cerebras.ai (free tier, ultra-fast)
CEREBRAS_API_KEY=YOUR_CEREBRAS_API_KEY
CEREBRAS_MODEL=llama-3.3-70b

# Mistral — get from https://console.mistral.ai (free tier, good classifier)
MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY
MISTRAL_MODEL=mistral-small-latest

# DeepSeek — get from https://platform.deepseek.com (free tier, strong reasoning)
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
DEEPSEEK_MODEL=deepseek-chat

# Sambanova — get from https://cloud.sambanova.ai (free tier, fast Llama)
SAMBANOVA_API_KEY=YOUR_SAMBANOVA_API_KEY
SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct

# ----- GitHub (optional for v1 — unauthenticated REST is used by default) -----
# If rate-limited, create a personal access token with no scopes (read public only)
# GITHUB_TOKEN=

# ----- Maintainer -----
# Used in User-Agent headers for outbound HTTP
MAINTAINER_EMAIL=you@yourdomain.com

# ----- Logging -----
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
