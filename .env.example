# ============================================================
# AI Roadmap Platform — Environment Variables
# ------------------------------------------------------------
# Copy this file to .env and fill in real values.
# NEVER commit .env. It's in .gitignore for a reason.
# ============================================================

# ----- Core -----
ENV=dev                            # dev | prod
PUBLIC_BASE_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080

# ----- Database -----
DATABASE_URL=sqlite+aiosqlite:////data/app.db

# ----- Auth / Sessions -----
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme_generate_a_real_32_byte_hex_string
JWT_EXPIRY_DAYS=30

# ----- Google OAuth2 -----
# Get from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# ----- SMTP for OTP email -----
# Resend (recommended): 3000/month free, DKIM signing, no "via gmail.com"
# Other options: Brevo (300/day), SendGrid (100/day), Gmail App Password
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=re_YOUR_RESEND_API_KEY
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=AutomateEdge
SMTP_USE_TLS=true  # true for port 465 (Resend/SSL), false for port 587 (Gmail/STARTTLS)

# ----- AI Providers -----
# Gemini — get from https://aistudio.google.com (free tier)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-1.5-flash

# Groq — get from https://console.groq.com (free tier)
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile

# Cerebras — get from https://cloud.cerebras.ai (free tier, ultra-fast)
CEREBRAS_API_KEY=YOUR_CEREBRAS_API_KEY
CEREBRAS_MODEL=llama3.1-8b

# Mistral — get from https://console.mistral.ai (free tier, good classifier)
MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY
MISTRAL_MODEL=mistral-small-latest

# DeepSeek — get from https://platform.deepseek.com (free tier, strong reasoning)
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
DEEPSEEK_MODEL=deepseek-chat

# Sambanova — get from https://cloud.sambanova.ai (free tier, fast Llama)
SAMBANOVA_API_KEY=YOUR_SAMBANOVA_API_KEY
SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct

# Anthropic Claude — RESERVED for curriculum generation, topic discovery, news/jobs ONLY
# Do NOT add to general fallback chain — paid API, use sparingly
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI — RESERVED for embeddings-based semantic topic dedup ONLY
# Do NOT add to generation/review/refine chain — use text-embedding-3-small ($0.02/1M tokens)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- Admin API keys (for nightly authoritative-spend sync only) ----
# These are DIFFERENT from the regular API keys above. Create them in each
# provider's dashboard under "Admin keys" / "Organization admin keys".
# They're used only by services/provider_usage_sync.py, never for inference.
OPENAI_ADMIN_API_KEY=YOUR_OPENAI_ADMIN_KEY
ANTHROPIC_ADMIN_API_KEY=YOUR_ANTHROPIC_ADMIN_KEY

# Days of raw ai_usage_log rows to retain. Older rows get archived into
# ai_usage_log_archive (long-term aggregates live in provider_daily_spend).
AI_USAGE_LOG_RETENTION_DAYS=90

# ----- GitHub (optional for v1 — unauthenticated REST is used by default) -----
# If rate-limited, create a personal access token with no scopes (read public only)
# GITHUB_TOKEN=

# ----- Affiliate -----
# Coursera affiliate program (Impact.com partner) — sign up at:
#   https://www.coursera.org/about/affiliates
# When set, coursera.org/{learn,specializations}/* links served on authenticated
# plan endpoints get an ?irclickid=... tracking param appended. Leave empty to
# disable the rewriter entirely. Never applied on public_profile / share / verify.
COURSERA_AFFILIATE_ID=

# ----- IndexNow (Bing/Yandex instant indexing for /jobs publishes) -----
# Generate: openssl rand -hex 16
# The key is auto-served at /<key>.txt for ownership verification. See docs/JOBS.md §7.5.
# Leave empty to disable IndexNow (dev default).
INDEXNOW_KEY=

# ----- Maintainer -----
# Used in User-Agent headers for outbound HTTP
MAINTAINER_EMAIL=you@yourdomain.com

# ----- Logging -----
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR

# ----- X / Twitter API (Phase B daily auto-post queue) -----
# All four required for posting via /admin/social. Get them from
# developer.x.com → app → Keys and tokens. Leave empty to keep the queue
# in "preview only" mode — drafts still queue at 8am IST and the admin UI
# works, but the Post button returns 503 with a clear "not configured"
# message until all four are set.
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ----- Programmatic notification endpoint -----
# Bearer token for POST /admin/api/notify. Used by scheduled remote agents
# (claude.ai routines etc.) that need to email the maintainer but can't use
# OAuth-based connectors. Generate with: openssl rand -hex 32
# Leave empty to disable the endpoint entirely (returns 503).
# Recipient is hardcoded to MAINTAINER_EMAIL — a leaked token can only spam
# that one inbox, not arbitrary addresses.
NOTIFY_API_TOKEN=
