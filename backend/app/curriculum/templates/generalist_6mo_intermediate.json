      "checkpoint": "Comfortable in Pandas/NumPy/SQL · 4 notebooks shipped · Stats vocab nailed · Repo public",
      "weeks": [
        {
          "n": 1, "t": "Python, SQL & Dev Environment", "hours": 16,
          "focus": ["Python: NumPy, Pandas, Matplotlib", "SQL: joins, CTEs, window functions", "Dev setup: VS Code, Jupyter, Git, GitHub", "Repo `ai-journey` created"],
          "deliv": ["EDA notebook on a public dataset", "30+ SQL exercises completed", "Repo live with README"],
          "resources": [
            {"name": "Pandas — Getting Started Tutorials", "url": "https://pandas.pydata.org/docs/getting_started/intro_tutorials/index.html", "hrs": 5},
            {"name": "SQLBolt — Interactive SQL Lessons", "url": "https://sqlbolt.com", "hrs": 4},
            {"name": "Kaggle Learn — Pandas", "url": "https://www.kaggle.com/learn/pandas", "hrs": 4}
